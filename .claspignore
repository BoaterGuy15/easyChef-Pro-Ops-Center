# Push only .gs files, cockpit.html, and the manifest to Apps Script
node_modules/**
package.json
package-lock.json
cockpit-mcp-server.js
cockpit-mcp-server-config.json
*.html
!cockpit.html
*.xlsx
*.md
CNAME
.clasp.json
.claspignore
.github
.claude
# Stub file — cockpit HTML is served from cockpit.html, not this file
cockpit_template.gs
# Node.js chain runners — local only
run-fix-chain.js
run-gas.js
run-gpt-chain.js
# Figma plugin — loaded by Figma desktop directly, never pushed to GAS
figma-plugin/**
# Cloudflare Worker — deployed via wrangler, not clasp
cf-worker/**
# Firebase deploy folder — deployed via firebase CLI
firebase-deploy/**
# Agent skills and submodules — not GAS
.agents/**
# Scratch/temp files
tmp_*
